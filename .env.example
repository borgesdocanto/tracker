# ─── NEXT AUTH ───────────────────────────────────────────────────
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=               # https://tu-app.vercel.app

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_DOMAIN=             # opcional: restringe a un dominio

# ─── SUPABASE ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── MERCADOPAGO ──────────────────────────────────────────────────
MP_ACCESS_TOKEN=

# ─── RESEND (emails) ──────────────────────────────────────────────
# Gratis hasta 3000 mails/mes: resend.com
RESEND_API_KEY=

# ─── ANTHROPIC (Insta Coach) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── CRON SECURITY ────────────────────────────────────────────────
# Secret para proteger el endpoint del cron: openssl rand -base64 16
CRON_SECRET=

# ─── PRODUCTIVIDAD ────────────────────────────────────────────────
NEXT_PUBLIC_PRODUCTIVITY_GOAL=10
