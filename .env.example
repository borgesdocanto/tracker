# ─── NEXT AUTH ───────────────────────────────────────────────────
NEXTAUTH_SECRET=TU_SECRET_RANDOM_ACA
NEXTAUTH_URL=https://TU_DOMINIO.vercel.app

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET

# ─── DOMINIO PERMITIDO (opcional) ─────────────────────────────────
ALLOWED_DOMAIN=galas.com.ar

# ─── SUPABASE ─────────────────────────────────────────────────────
# En: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXX   # NUNCA exponer al browser

# ─── MERCADOPAGO ──────────────────────────────────────────────────
# En: mercadopago.com.ar → Tu negocio → Credenciales
MP_ACCESS_TOKEN=APP_USR-XXXX       # Access token productivo

# ─── PRODUCTIVIDAD ────────────────────────────────────────────────
NEXT_PUBLIC_PRODUCTIVITY_GOAL=10
